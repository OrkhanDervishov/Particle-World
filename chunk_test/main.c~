

#include <stdio.h>
#include <time.h>
#include "engine/engine_api.h"

#define WINDOW_TITLE "Test window"
#define WINDOW_WIDTH 720
#define WINDOW_HEIGHT 720
#define PART_SIZE 10
#define CHUNK_SIZE 16
#define WORLD_SIZE 5

#define PLAYER_WIDTH 30
#define PLAYER_HEIGHT 60

typedef struct{
    Color color;
} Part;

typedef struct{
    int chunk_x, chunk_y;
    Part parts[CHUNK_SIZE][CHUNK_SIZE];
} Chunk;

typedef struct{
    int field_x, field_y;
    Chunk chunks[WORLD_SIZE][WORLD_SIZE];
} Field;


#define FIELD_GET_PART(f, x, y) (f).chunks[]


typedef struct{
    Color color;
    int x, y;
} Player;


int RandomGenerator(){
    switch (rand() % 2)
    {
    case 0:
	return 0xFF777777;
    case 1:
	return 0xFFFFFFFF;
    }    
}

int PerlinGenerator(int x, int y){
  return 0;
}


void CreateChunk(Chunk *chunk, int chunk_x, int chunk_y){
    for(int i = 0; i < CHUNK_SIZE; i++)
    for(int j = 0; j < CHUNK_SIZE; j++){
        chunk->parts[i][j].color.rgba = RandomGenerator();
    }
}

void CreateField(Field *field){
    for(int i = 0; i < WORLD_SIZE; i++)
    for(int j = 0; j < WORLD_SIZE; j++){
      CreateChunk(&field->chunks[i][j], j, i);
    }
}

void CreatePlayer(Player *p, int x, int y, int rgba){
    p->x = x;
    p->y = y;
    p->color.rgba = rgba;
}

void DrawChunk(Window *window, Chunk *chunk, int x, int y){
    int endx = x + CHUNK_SIZE;
    int endy = y + CHUNK_SIZE;
    for(int i = y; i < endy; i++)
    for(int j = x; j < endx; j++){
        Part p = chunk->parts[i - y][j - x];
        SDL_Rect r = {
            .x = j * PART_SIZE,
            .y = i * PART_SIZE,
            .w = PART_SIZE,
            .h = PART_SIZE
        };
        SDL_SetRenderDrawColor(
            window->renderer,
            p.color.r,
            p.color.g,
            p.color.b,
            p.color.a
        );
        SDL_RenderFillRect(window->renderer, &r);
    }
}

void DrawField(Window *window, Field *field){
    for(int i = 0; i < WORLD_SIZE; i++)
    for(int j = 0; j < WORLD_SIZE; j++){
        // if((j + i) % 2 != 0) continue;
        Chunk chunk = field->chunks[i][j];
        DrawChunk(window, &chunk, j * CHUNK_SIZE, i * CHUNK_SIZE);
    }
}


void DrawPlayer(Window *window, Player *p){
    SDL_SetRenderDrawColor(
        window->renderer,
        p->color.r,
        p->color.g,
        p->color.b,
        p->color.a
    );
    SDL_Rect r = {
        .x = p->x,
        .y = p->y,
        .w = PLAYER_WIDTH,
        .h = PLAYER_HEIGHT
    };
    SDL_RenderFillRect(window->renderer, &r);
}


int main(int argc, char* argv[]){
    Window* window;
    CreateWindow(&window, WINDOW_WIDTH, WINDOW_HEIGHT, WIN_TITLE);
    srand(time(NULL));

    Chunk chunk;
    CreateChunk(&chunk, 0, 0);

    Field field;
    CreateField(&field);

    Player player;
    CreatePlayer(&player, WINDOW_WIDTH / 2, WINDOW_HEIGHT / 2, 0xFFFF0000);

    SDL_Event e;
    int x = CHUNK_SIZE, y = CHUNK_SIZE, mov = 15;
    while(window->isrunning){

        while(SDL_PollEvent(&e)){
            if(e.type == SDL_QUIT){
                window->isrunning = FALSE;
            }
            if(e.key.keysym.sym == SDLK_w){
                player.y -= mov;
            }
            if(e.key.keysym.sym == SDLK_s){
                player.y += mov;
            }
            if(e.key.keysym.sym == SDLK_d){
                player.x += mov;
            }
            if(e.key.keysym.sym == SDLK_a){
                player.x -= mov;
            }
        }

        SDL_SetRenderDrawColor(window->renderer, 100, 100, 100, 255);
        SDL_RenderClear(window->renderer);
        // DrawChunk(window, &chunk, x, y);
        DrawField(window, &field);
        DrawPlayer(window, &player);
        SDL_RenderPresent(window->renderer);

        SDL_Delay(10);
    }

    DestroyWindow(&window);
    return 0;
}
